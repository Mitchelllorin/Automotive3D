# Copy to android/keystore.properties (gitignored) and fill in your upload-key
# credentials. Create the key with:
#   keytool -genkeypair -v -keystore android/upload-keystore.jks -storetype JKS \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias upload
# Losing storePassword means you can never update the app — save it in a password manager.
storeFile=upload-keystore.jks
keyAlias=upload
storePassword=
keyPassword=
